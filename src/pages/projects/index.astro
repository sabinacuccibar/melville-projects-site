---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");

projects.sort((a, b) => Number(b.data.year) - Number(a.data.year));
---

<BaseLayout title="Projects | Melville Projects">
  <section class="page">
    <p class="eyebrow">Projects</p>
    <h1>Project sheets</h1>
    <p>
      A text-based archive of selected projects, collaborations, proposals, and strategic work.
    </p>

    <div class="list">
      {projects.map((project) => (
        <article class="list-item">
          <div class="meta">
            {project.data.year}
            {project.data.field && <> · {project.data.field}</>}
          </div>
          <h2>{project.data.title}</h2>
          {project.data.organisation && <p><strong>Organisation:</strong> {project.data.organisation}</p>}
          {project.data.role && <p><strong>Role:</strong> {project.data.role}</p>}
          <p>
            <a href={`/projects/${project.slug}`}>Read project sheet</a>
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>