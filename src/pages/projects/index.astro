---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects | Melville Projects">
  <section class="page">
    <p class="eyebrow">Projects</p>
    <h1>Project sheets</h1>
    <p>
      A text-based archive of selected projects, collaborations, proposals, and strategic work.
    </p>

    <div class="list">
      <article class="list-item">
        <div class="meta">2026 · EU funding / public innovation</div>
        <h2>Sample project sheet</h2>
        <p>
          Short description of the project, the role, and the type of contribution.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>