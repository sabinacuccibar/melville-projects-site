---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");

projects.sort((a, b) => Number(b.data.year ?? 0) - Number(a.data.year ?? 0));

const getSlug = (id: string) => id.replace(/\.md$/, "");
---

<BaseLayout title="Projects | Melville Projects">
  <section class="page">
    <p class="eyebrow">Projects</p>
    <h1>Project sheets</h1>
    <p>
      A text-based archive of selected projects, collaborations, proposals, and strategic work.
    </p>

    <div class="list">
      {projects.map((project) => (
        <article class="list-item">
          {project.data.year && (
            <div class="meta">{project.data.year}</div>
          )}

          <h2>{project.data.title}</h2>

          {project.data.subtitle && (
            <p class="project-list-subtitle">{project.data.subtitle}</p>
          )}

         <p class="project-read-link">
          <a href={`/projects/${getSlug(project.id)}`}>Read project</a>
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>