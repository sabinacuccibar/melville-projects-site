---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | Melville Projects`}>
  <article class="project-page">
    <header class="project-header">
      {project.data.year && <p class="eyebrow">{project.data.year}</p>}
      <h1>{project.data.title}</h1>
      {project.data.subtitle && <p class="project-subtitle">{project.data.subtitle}</p>}
    </header>

    {project.data.image && (
      <figure class="project-image">
        <img src={project.data.image} alt="" />
      </figure>
    )}

    <div class="project-body">
      <Content />
    </div>

    {project.data.partners && (
      <aside class="project-partners">
        <p class="project-partners-label">Partners / commissioners</p>
        <p>{project.data.partners}</p>
      </aside>
    )}
  </article>
</BaseLayout>