---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const notes = await getCollection("notes");

notes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getSlug = (id: string) => id.replace(/\.md$/, "");
---

<BaseLayout title="Notes | Melville Projects">
  <section class="page">
    <p class="eyebrow">Notes</p>
    <h1>Short notes</h1>
    <p>
      Short texts, observations, working notes, and reflections.
    </p>

    <div class="list">
      {notes.map((note) => (
        <article class="list-item">
          <div class="meta">
            {note.data.date.toLocaleDateString("en-GB", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </div>
          <h2>{note.data.title}</h2>
          {note.data.excerpt && <p>{note.data.excerpt}</p>}
          <p>
            <a href={`/notes/${getSlug(note.id)}`}>Read note</a>
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>